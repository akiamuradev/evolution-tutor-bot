# Telegram
TG_BOT_TOKEN=replace-with-telegram-bot-token
BOT_USERNAME=@replace_with_bot_username
TG_PROXY_URL=
ADMIN_IDS=
UNLIMITED_USERS=

# LiteLLM Proxy
LITELLM_BASE_URL=http://litellm:4000
LITELLM_API_KEY=replace-with-litellm-api-key

# OpenRouter (LLM Provider)
OPENROUTER_API_KEY=replace-with-openrouter-api-key
OPENROUTER_MODEL=qwen/qwen-2.5-72b-instruct
OPENROUTER_FAST_MODEL=qwen/qwen-2.5-72b-instruct
OPENROUTER_REASONING_MODEL=deepseek/deepseek-r1
OPENROUTER_FALLBACK_MODEL=google/gemini-2.5-pro
OPENROUTER_MAX_TOKENS=1800
OPENROUTER_FAST_MAX_TOKENS=900
OPENROUTER_REASONING_MAX_TOKENS=2500
MAX_CONCURRENT_AI_REQUESTS=20
AI_QUEUE_WAIT_SECONDS=45
MAX_WAITING_AI_REQUESTS=200
MAX_CONCURRENT_UPDATES=200
ANTISPAM_MIN_INTERVAL_SECONDS=0.5
ANTISPAM_WINDOW_SECONDS=20
ANTISPAM_MAX_EVENTS_PER_WINDOW=10
ANTISPAM_COOLDOWN_SECONDS=15
ANTISPAM_NOTIFY_INTERVAL_SECONDS=10
ANTISPAM_MESSAGE_MIN_INTERVAL_SECONDS=0.5
ANTISPAM_MESSAGE_WINDOW_SECONDS=20
ANTISPAM_MESSAGE_MAX_EVENTS_PER_WINDOW=10
ANTISPAM_MESSAGE_COOLDOWN_SECONDS=15
ANTISPAM_COMMAND_MIN_INTERVAL_SECONDS=0.25
ANTISPAM_COMMAND_WINDOW_SECONDS=10
ANTISPAM_COMMAND_MAX_EVENTS_PER_WINDOW=12
ANTISPAM_COMMAND_COOLDOWN_SECONDS=10
ANTISPAM_CALLBACK_MIN_INTERVAL_SECONDS=0.2
ANTISPAM_CALLBACK_WINDOW_SECONDS=10
ANTISPAM_CALLBACK_MAX_EVENTS_PER_WINDOW=20
ANTISPAM_CALLBACK_COOLDOWN_SECONDS=8
ANTISPAM_API_CHAT_MIN_INTERVAL_SECONDS=0.8
ANTISPAM_API_CHAT_WINDOW_SECONDS=20
ANTISPAM_API_CHAT_MAX_EVENTS_PER_WINDOW=8
ANTISPAM_API_CHAT_COOLDOWN_SECONDS=20
ANTISPAM_API_PRACTICE_MIN_INTERVAL_SECONDS=0.4
ANTISPAM_API_PRACTICE_WINDOW_SECONDS=20
ANTISPAM_API_PRACTICE_MAX_EVENTS_PER_WINDOW=14
ANTISPAM_API_PRACTICE_COOLDOWN_SECONDS=15
RAG_CONTEXT_TASK_LIMIT=3
RAG_MIN_CONFIDENCE=0.22

# VK/Web HTTP API
WEB_API_PORT=8080
WEB_API_CORS_ORIGIN=*
WEB_API_MAX_TEXT_LENGTH=4000
WEB_API_ALLOW_UNSIGNED_VK_LAUNCH=true
WEB_API_ALLOW_INSECURE_USER_ID=false

# VK Mini App
VK_APP_ID=replace-with-vk-mini-app-id
VK_APP_SECRET=replace-with-vk-mini-app-secret
VK_LAUNCH_PARAMS_MAX_AGE_SECONDS=86400

# PostgreSQL
POSTGRES_USER=tutor_user
POSTGRES_PASSWORD=replace-with-postgres-password
POSTGRES_DB=tutor_db
DATABASE_URL=postgresql://tutor_user:replace-with-postgres-password@postgres:5432/tutor_db

# YooKassa
YOOKASSA_SHOP_ID=replace-with-yookassa-shop-id
YOOKASSA_SECRET_KEY=replace-with-yookassa-secret-key
